# Copy to .env and set keys you need. Defaults for models live in ~/.spark/config.yaml.

# --- LLM providers (keys) ---
# OpenRouter — https://openrouter.ai/keys (vision/MoA helpers; main chat uses config model)
# OPENROUTER_API_KEY=

# Google AI Studio / Gemini — https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=
# GEMINI_API_KEY=              # alias for GOOGLE_API_KEY
# GEMINI_BASE_URL=             # default: Google OpenAI-compat endpoint

# z.ai / GLM — https://z.ai
# GLM_API_KEY=
# GLM_BASE_URL=https://api.z.ai/api/paas/v4

# Kimi / Moonshot — https://platform.kimi.ai (sk-kimi-* → api.kimi.com; legacy Moonshot needs KIMI_BASE_URL)
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_CN_API_KEY=

# Arcee — https://chat.arcee.ai/
# ARCEEAI_API_KEY=
# ARCEE_BASE_URL=

# MiniMax — https://www.minimax.io (China: minimaxi.com)
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_CN_API_KEY=
# MINIMAX_CN_BASE_URL=https://api.minimaxi.com/v1

# OpenCode Zen — https://opencode.ai/auth
# OPENCODE_ZEN_API_KEY=
# OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1

# OpenCode Go — https://opencode.ai/auth ($10/mo)
# OPENCODE_GO_API_KEY=
# OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# Hugging Face Inference Providers — token needs "Inference Providers" — https://huggingface.co/settings/tokens
# HF_TOKEN=

# Qwen OAuth — uses ~/.qwen/oauth_creds.json from `qwen auth qwen-oauth`; optional:
# SPARK_QWEN_BASE_URL=https://portal.qwen.ai/v1

# Xiaomi MiMo — https://platform.xiaomimimo.com
# XIAOMI_API_KEY=
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# LLM_MODEL is not read from .env; use `spark model` / config.yaml.
# LLM_MODEL=anthropic/claude-opus-4.6

# --- Tool APIs ---
# EXA_API_KEY=          # https://exa.ai
# PARALLEL_API_KEY=     # https://parallel.ai
# FIRECRAWL_API_KEY=    # https://firecrawl.dev/
# FAL_KEY=              # https://fal.ai/ (image gen)
# HONCHO_API_KEY=       # https://app.honcho.dev — also ~/.honcho/config.json enabled=true

# --- Terminal (override config terminal.* / TERMINAL_ENV only if you must) ---
# Backends: local | docker | singularity | modal | ssh — usually set in config.yaml, not here.
# TERMINAL_ENV=local
# TERMINAL_DOCKER_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
# TERMINAL_SINGULARITY_IMAGE=docker://nikolaik/python-nodejs:python3.11-nodejs20
TERMINAL_MODAL_IMAGE=nikolaik/python-nodejs:python3.11-nodejs20
# TERMINAL_CWD=.       # remote: absolute path inside target env, not host path
TERMINAL_TIMEOUT=60
TERMINAL_LIFETIME_SECONDS=300

# TERMINAL_SSH_HOST=
# TERMINAL_SSH_USER=
# TERMINAL_SSH_PORT=22
# TERMINAL_SSH_KEY=~/.ssh/id_rsa

# SUDO_PASSWORD=       # plaintext sudo -S; prefer passwordless sudo / root in containers / interactive CLI

# Modal: `pip install modal && modal setup` (no key in .env)

# --- Browser (Browserbase) — https://browserbase.com/ ---
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false
BROWSER_SESSION_TIMEOUT=300
BROWSER_INACTIVITY_TIMEOUT=120

# Trajectories: logs/session_YYYYMMDD_HHMMSS_UUID.json

# --- Voice (Whisper/TTS direct from OpenAI; not via OpenRouter) ---
# VOICE_TOOLS_OPENAI_KEY=   # https://platform.openai.com/api-keys

# --- Messaging / gateway ---
# SLACK_BOT_TOKEN=xoxb-…
# SLACK_APP_TOKEN=xapp-…
# SLACK_ALLOWED_USERS=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_HOME_CHANNEL=
# TELEGRAM_HOME_CHANNEL_NAME=
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_SECRET=
# WHATSAPP_ENABLED=false
# WHATSAPP_ALLOWED_USERS=15551234567
# Gmail: 2FA + App Password — https://myaccount.google.com/apppasswords
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_POLL_INTERVAL=15
# EMAIL_ALLOWED_USERS=
# EMAIL_HOME_ADDRESS=
# GATEWAY_ALLOW_ALL_USERS=false

# SPARK_HUMAN_DELAY_MODE=off          # off | natural | custom
# SPARK_HUMAN_DELAY_MIN_MS=800
# SPARK_HUMAN_DELAY_MAX_MS=2500

# --- OpenAI-compatible HTTP API (external apps) ---
# Exposes Spark with an OpenAI-compatible endpoint (/v1/*) for other apps; run `spark gateway` with this enabled.
# Clients send Authorization: Bearer <API_SERVER_KEY>. Non-loopback bind requires API_SERVER_KEY; weak placeholders are rejected.
# Default port if omitted: 8642. Optional: API_SERVER_CORS_ORIGINS, API_SERVER_MODEL_NAME — docs/integrations/api-server.md
# API_SERVER_ENABLED=true
# API_SERVER_KEY=PASSWORD
# API_SERVER_HOST=0.0.0.0
# API_SERVER_PORT=6789

# --- Debug ---
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false

# Context compression: config.yaml compression.* (not .env)

# --- RL (Tinker / Atropos) ---
# TINKER_API_KEY=       # https://tinker-console.thinkingmachines.ai/keys
# WANDB_API_KEY=        # https://wandb.ai/authorize
# RL_API_URL=http://localhost:8080

# --- Skills hub / STT ---
# GITHUB_TOKEN=ghp_…  # https://github.com/settings/tokens
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# GITHUB_APP_INSTALLATION_ID=
# GROQ_API_KEY=       # Whisper STT free tier; priority: local > groq > openai (stt in config.yaml)

# STT overrides (else stt.model in config.yaml)
# STT_GROQ_MODEL=whisper-large-v3-turbo
# STT_OPENAI_MODEL=whisper-1
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# STT_OPENAI_BASE_URL=https://api.openai.com/v1
