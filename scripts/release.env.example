# Release-signing config template.
#
# Copy this to scripts/release.env (gitignored) to make EVERY desktop build
# Developer ID signed + Apple-notarized automatically — build_desktop.sh sources
# scripts/release.env on each run, so /build-mac and /release-mac always produce
# a Gatekeeper-clean DMG with no manual `export` step.
#
# Setup (once):
#   1. Confirm your Developer ID Application identity is in the keychain:
#        security find-identity -v -p codesigning
#   2. Store the notarization app-specific password in the keychain ONCE
#      (the password is created at appleid.apple.com → Sign-In and Security →
#      App-Specific Passwords). This keeps the password OUT of any file:
#        xcrun notarytool store-credentials spark-notary \
#          --apple-id "you@example.com" --team-id "TEAMID"
#   3. Copy this file to scripts/release.env and fill in the three values below.
#
# These three values are NOT secret (cert name, profile name, team id) — the
# password is only in the keychain. scripts/release.env is gitignored anyway.

APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
APPLE_KEYCHAIN_PROFILE="spark-notary"
APPLE_TEAM_ID="TEAMID"
